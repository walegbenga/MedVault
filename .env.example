# ─── MedVault Environment Configuration ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Deployer wallet ───────────────────────────────────────────────────────────
# Private key of the wallet that will deploy the contract.
# Must have ETH on Base Mainnet / Base Sepolia for gas.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── RPC endpoints ─────────────────────────────────────────────────────────────
# Base Mainnet (default: public endpoint, no key needed for low traffic)
BASE_RPC_URL=https://mainnet.base.org

# Base Sepolia testnet
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: Alchemy / Infura for higher rate limits
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── BaseScan verification ─────────────────────────────────────────────────────
# Get free key at https://basescan.org/apis
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# ── WalletConnect ─────────────────────────────────────────────────────────────
# The project ID is hardcoded directly in frontend/index.html (line ~1045).
# This is a static HTML file — it cannot read .env variables at runtime.
# To use your own project ID, edit this line in index.html:
#   projectId: 'b56e18d47c72ab683b10814fe9495694'
# Get a free project ID at https://cloud.walletconnect.com

# ── IPFS (optional — for real encrypted file upload) ──────────────────────────
# Pinata: https://app.pinata.cloud/keys
PINATA_JWT=YOUR_PINATA_JWT
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Deployed contract addresses (written by deploy script) ───────────────────
# CONTRACT_ADDRESS_BASE=
# CONTRACT_ADDRESS_BASE_SEPOLIA=
