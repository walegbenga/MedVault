# ─── MedVault Root Environment ───────────────────────────────────────────────
# Used by Hardhat for contract deployment.
# Copy to .env — NEVER commit .env to git.

# ── Deployer wallet ───────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── RPC endpoints ─────────────────────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── BaseScan verification ─────────────────────────────────────────────────────
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# ── Pinata IPFS (used by Vercel serverless functions) ─────────────────────────
# Get JWT at https://app.pinata.cloud/keys
# Set these in Vercel dashboard under Environment Variables — NOT in this file
PINATA_JWT=YOUR_PINATA_JWT
PINATA_GATEWAY=https://yourname.mypinata.cloud
PINATA_GATEWAY_TOKEN=YOUR_GATEWAY_TOKEN_IF_PRIVATE
