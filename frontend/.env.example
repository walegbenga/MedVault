# ─── MedVault Frontend Environment ─────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real values.
#
# Vite rules:
#   VITE_*  → bundled into the browser (public, visible to users)
#   No prefix → server-side only, NEVER exposed to the browser
#
# ── WalletConnect ─────────────────────────────────────────────────────────────
# Required. Get a free project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# ── App metadata (shown in wallet connection prompts) ─────────────────────────
VITE_APP_NAME=MedVault
VITE_APP_DESCRIPTION=Patient-Controlled Health Records on Base
VITE_APP_URL=https://your-deployed-url.com
VITE_APP_ICON=https://your-deployed-url.com/icon.png

# ── Network ───────────────────────────────────────────────────────────────────
# base or base-sepolia
VITE_NETWORK=base

# ── Contract address (output from: npm run deploy:mainnet in root) ─────────────
# Leave empty on first run — the app will deploy your registry automatically.
# After deploying, paste the address here so the app skips re-deployment.
VITE_CONTRACT_ADDRESS=

# ── RPC override (optional — use Alchemy/Infura for better reliability) ────────
# Leave empty to use the default public Base RPC endpoint.
VITE_RPC_URL=
